# span-backend environment variables
# Copy to .env and fill in real values. NEVER commit .env.

# ── PostgreSQL ──────────────────────────────────────────────────────────────
# Plain PostgreSQL (NOT Aurora). Co-hosted on EC2 to start; split to its own
# box only when volume justifies it.
DATABASE_URL=postgres://span:changeme@localhost:5432/span

# ── AWS ─────────────────────────────────────────────────────────────────────
# All AWS resources MUST be in ap-south-1 (Mumbai). India-only product.
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY

# S3 bucket for raw artifacts (PDFs, photos). SSE-KMS enforced via bucket policy.
S3_BUCKET=span-artifacts-in

# SQS FIFO queue URL for the parse/analyze job queue.
SQS_QUEUE_URL=https://sqs.ap-south-1.amazonaws.com/123456789012/span-jobs.fifo

# KMS key ID used for SSE-KMS on S3 and any application-level encryption.
KMS_KEY_ID=arn:aws:kms:ap-south-1:123456789012:key/mrk-00000000000000000000000000000000

# ── Vertex AI (Google Cloud) ─────────────────────────────────────────────────
# Inference MUST use asia-south1 (Mumbai) to satisfy DPDP residency.
# HARD RULE: Claude / Anthropic APIs are EXCLUDED from the India path.
VERTEX_PROJECT=your-gcp-project-id
VERTEX_LOCATION=asia-south1

# Path to GCP service account key JSON (or use Application Default Credentials on EC2).
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ── Sarvam AI (voice) ────────────────────────────────────────────────────────
# All-in-India STT / LLM / TTS for the voice consultant. Satisfies DPDP for voice.
SARVAM_API_KEY=sarvam_sk_example_00000000000000000000000000000000

# ── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# Apple Sign In — bundle ID / client ID for token verification.
APPLE_CLIENT_ID=ai.sigiq.span
